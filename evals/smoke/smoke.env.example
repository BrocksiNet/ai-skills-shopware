# Copy to evals/smoke/smoke.env and adjust (smoke.env is gitignored).
#
# Skills symlinked into each task workdir when mode=on (.claude/.codex/.cursor/skills).
SMOKE_SKILLS="php-foundation shopware-testing shopware-review-learnings"

# Default A/B smoke suite (easy + harder tasks; override to trim cost).
SMOKE_TASKS="no-empty-explicit backed-enum-over-constants unit-test-passes clock-interface-injection unit-test-exception-object interface-di-repository cache-tag-no-deprecated-event phpstan-baseline-guardrail core-http-client-behind-flag"

# Agents to try (space-separated). Cursor: use `agent login` locally; omit admin crsr_ keys.
SMOKE_AGENTS="claude codex cursor"

# Optional overrides (unset = auto-detect from PATH + auth).
# Avoid unavailable default models (e.g. Fable 5): sonnet | opus | haiku
# SMOKE_CLAUDE_MODEL=sonnet
# SMOKE_CLAUDE_CMD='claude -p --dangerously-skip-permissions --output-format text'
# SMOKE_CODEX_CMD='codex exec --dangerously-bypass-approvals-and-sandbox -s workspace-write'
# CURSOR_API_KEY=...   # export recommended; user key from dashboard/integrations (not Admin API)

# CI: set SMOKE_CI=1 to fail when no agent is runnable.
# SMOKE_STRICT=1 — fail suite when skills-on does not beat skills-off (use in CI).
# SMOKE_CI=0
